# Email service configuration (required for the contact form to send emails)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# The "from" email address — must be on a domain verified in your Resend account.
RESEND_FROM_EMAIL=Krypton Digital <noreply@kryptondigital.com>

# The email address that receives contact form submissions
CONTACT_TO_EMAIL=contact@kryptondigital.com
