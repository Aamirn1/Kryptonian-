# Email service configuration (required for the contact form to send emails)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# The "from" email address — must be a domain verified in your Resend account.
# For testing, you can use onboarding@resend.dev (only sends to your account email).
# For production, set this to an address on your verified domain, e.g.:
# RESEND_FROM_EMAIL=Krypton Digital <noreply@kryptondigital.co.uk>
RESEND_FROM_EMAIL=Krypton Digital <noreply@kryptondigital.co.uk>

# The email address that receives contact form submissions
CONTACT_TO_EMAIL=contact@kryptondigital.co.uk
